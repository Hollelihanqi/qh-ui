{
  "name": "hd",
  "version": "2.0.1",
  "type": "module",
  "scripts": {
    "gc": "tsx scripts/create-component.ts",
    "gc:template": "tsx scripts/create-component-template.ts",
    "watch:components": "tsx scripts/watch-components.ts",
    "gen-component-import": "tsx scripts/gen-component-import.ts",
    "rc": "tsx scripts/remove-component.ts",
    "clean": "pnpm run clean:dist",
    "clean:dist": "rimraf dist",
    "build": "pnpm exec nx run @rdeam/hd-ui:build --outputStyle=stream",
    "play:dev": "pnpm run -C play dev",
    "docs:dev": "pnpm run -C docs docs:dev",
    "docs:build": "pnpm run -C docs docs:build",
    "docs:preview": "pnpm run -C docs docs:preview",
    "docs:deploy": "powershell -ExecutionPolicy Bypass -File ./docs/deploy.ps1",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "format": "prettier --write .",
    "commit": "git add -A && pnpm exec git-cz && git push",
    "check-git": "git diff-index --quiet HEAD || (echo '发现未提交的代码改动，请先执行 pnpm commit 提交代码' && exit 1)",
    "update-version": "pnpm exec nx release version --projects=@rdeam/hd-ui",
    "commit-version": "git add packages/hd-custom/package.json pnpm-lock.yaml && git commit -m \"chore(release): update package version\" || true",
    "build-after-version": "pnpm build",
    "tag-version": "tsx scripts/tag-version.ts",
    "publish-custom": "cd dist/hd-custom && npm publish",
    "publish:dist": "tsx scripts/publish.ts",
    "push-tags": "git push origin --tags && git push",
    "release:ui": "pnpm check-git && pnpm update-version && pnpm commit-version && pnpm tag-version && pnpm build-after-version && pnpm publish-custom && pnpm push-tags",
    "clean:cache": "pnpm exec nx reset",
    "build:verbose": "NX_VERBOSE_LOGGING=true pnpm build",
    "prepare": "husky install",
    "build:vite": "pnpm run -C internal/build2 build"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@nx/js": "^22.7.0",
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^11.0.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.32",
    "@types/node": "^25.6.0",
    "@unocss/core": "66.6.8",
    "@unocss/postcss": "66.6.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/runtime-dom": "^3.5.33",
    "@vue/tsconfig": "0.9.1",
    "@hd/eslint-config": "workspace:*",
    "chokidar": "^5.0.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.13.0",
    "element-plus": "^2.13.7",
    "esbuild": "0.28.0",
    "eslint": "^10.2.1",
    "fast-glob": "^3.3.3",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "magic-string": "^0.30.21",
    "nx": "22.7.0",
    "postcss-apply": "^0.12.0",
    "prettier": "^3.8.3",
    "release-it": "20.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "through2": "^4.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "type-fest": "^5.6.0",
    "typescript": "6.0.3",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-element-plus": "^0.11.2",
    "unplugin-vue-components": "^32.0.0",
    "unplugin-vue-macros": "^2.14.5",
    "vite": "^8.0.10",
    "vite-plugin-vue-setup-extend": "^0.4.0",
    "vue-tsc": "^3.2.7"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vue/runtime-core": "^3.5.33",
    "@vue/shared": "^3.5.33",
    "@vueuse/core": "^14.2.1",
    "@hd-custom/build-constants": "workspace:^",
    "@hd-custom/build-utils": "workspace:*",
    "@hd-custom/components": "workspace:^",
    "@hd-custom/directives": "workspace:^",
    "@hd-custom/hooks": "workspace:^",
    "@hd-custom/utils": "workspace:^",
    "@hd-custom/share": "workspace:*",
    "axios": "^1.15.2",
    "echarts": "^6.0.0",
    "fs-extra": "^11.3.4",
    "gold-core": "0.2.0",
    "immutable": "^5.1.5",
    "lodash-unified": "^1.0.3",
    "moment": "^2.30.1",
    "remove": "^0.1.5",
    "rimraf": "^6.1.3",
    "simple-uploader.js": "^0.6.0",
    "spark-md5": "^3.0.2",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  }
}

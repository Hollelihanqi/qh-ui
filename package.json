{
  "name": "yto",
  "version": "2.0.1",
  "type": "module",
  "scripts": {
    "gc": "pnpm exec bash scripts/create-component2.sh",
    "watch:components": "tsx scripts/watch-components.ts",
    "gen-component-import": "tsx scripts/gen-component-import.ts",
    "rc": "pnpm exec bash scripts/remove-component.sh",
    "clean": "pnpm run clean:dist",
    "clean:dist": "rimraf dist",
    "prebuild": "npx nx run-many -t build -p yto-utils,internal-build-constants,internal-build-utils,internal-resolvers",
    "build": "pnpm run -C internal/build start",
    "build:utils": "pnpm run -C packages/yto-utils build",
    "play:dev": "pnpm run -C play dev",
    "docs:dev": "pnpm run -C docs docs:dev",
    "docs:build": "pnpm run -C docs docs:build",
    "docs:preview": "pnpm run -C docs docs:preview",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "format": "prettier --write .",
    "commit": "git add -A && git-cz && git push",
    "check-git": "git diff-index --quiet HEAD || (echo '发现未提交的代码改动，请先执行 pnpm commit 提交代码' && exit 1)",
    "update-version": "npx nx release version --projects=@yto/custom",
    "commit-version": "git add packages/yto-custom/package.json && git commit -m \"chore(release): update package version\" || true",
    "build-after-version": "pnpm build",
    "publish-custom": "cd dist/yto-custom && npm publish",
    "push-tags": "git push origin --tags && git push",
    "release:ui": "pnpm check-git && pnpm update-version && pnpm commit-version && pnpm build-after-version && pnpm publish-custom && pnpm push-tags",
    "release:utils": "pnpm -C packages/yto-utils release",
    "clean:cache": "npx nx reset",
    "build:verbose": "NX_VERBOSE_LOGGING=true pnpm build",
    "prepare": "husky install",
    "build:vite": "pnpm run -C internal/build2 build"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.8.0",
    "@commitlint/config-conventional": "^17.8.0",
    "@nx/js": "^20.5.0",
    "@release-it/bumper": "^5.1.0",
    "@release-it/conventional-changelog": "^7.0.2",
    "@rollup/plugin-alias": "^5.1.1",
    "@swc-node/register": "^1.10.9",
    "@swc/core": "^1.11.8",
    "@unocss/core": "0.53.4",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/runtime-dom": "^3.5.13",
    "@yto/eslint-config": "9.10.0-9",
    "chokidar": "^3.6.0",
    "cz-git": "^1.7.1",
    "element-plus": "^2.9.4",
    "fast-glob": "^3.2.11",
    "glob": "^11.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.3.0",
    "magic-string": "^0.30.17",
    "nx": "20.5.0",
    "postcss-apply": "^0.12.0",
    "release-it": "18.1.2",
    "rollup-plugin-visualizer": "^5.9.2",
    "sass": "^1.83.4",
    "through2": "^4.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "type-fest": "^4.27.0",
    "typescript": "5.5.4",
    "unocss": "^0.48.0",
    "unplugin-auto-import": "^0.16.6",
    "unplugin-element-plus": "^0.8.0",
    "unplugin-vue-components": "^0.25.2",
    "unplugin-vue-macros": "^0.11.2",
    "vite": "^6.2.4",
    "vite-plugin-vue-setup-extend": "^0.4.0",
    "vue-tsc": "^2.1.6"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "@types/node": "^18.18.5",
    "@vitejs/plugin-vue-jsx": "^4.1.2",
    "@vue/runtime-core": "^3.3.4",
    "@vue/shared": "^3.2.37",
    "@vueuse/core": "^12.4.0",
    "@yto-custom/build-constants": "workspace:^",
    "@yto-custom/build-utils": "workspace:*",
    "@yto-custom/components": "workspace:^",
    "@yto-custom/directives": "workspace:^",
    "@yto-custom/hooks": "workspace:^",
    "@yto-custom/utils": "workspace:^",
    "@yto/utils": "workspace:*",
    "axios": "^1.3.5",
    "echarts": "^5.4.3",
    "fs-extra": "^11.1.1",
    "gold-core": "0.1.17",
    "immutable": "^4.3.4",
    "lodash-unified": "^1.0.3",
    "moment": "^2.29.4",
    "remove": "^0.1.5",
    "rimraf": "^5.0.5",
    "simple-uploader.js": "^0.6.0",
    "spark-md5": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.2.5"
  },
  "engines": {
    "node": ">=18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  }
}

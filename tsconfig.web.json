{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "preserve",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "noImplicitAny": false,
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "unplugin-vue-macros/macros-global",
      "vite/client",
      "@vue/runtime-dom"
    ],
    "skipLibCheck": true,
  },
  "include": [
    "packages",
    "typings/env.d.ts",
    "packages/components/**/*.tsx"
, "internal/resolve"  ],
  "exclude": [
    "node_modules",
    "../dist",
    "**/gulpfile.ts",
    "**/*.md",
    "template/*",
  ]
}
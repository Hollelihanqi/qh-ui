{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "noUnusedLocals": false,
    "noImplicitAny": false,
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "unplugin-vue-macros/macros-global",
      "vite/client",
      "@vue/runtime-dom"
    ],
    "skipLibCheck": true,
  },
  "include": [
    "typings/env.d.ts",
    "packages/hd-custom",
    "packages/components",
    "packages/directives",
    "packages/hooks",
    "packages/utils"
  ],
  "exclude": [
    "node_modules",
    "../dist",
    "**/gulpfile.ts",
    "**/*.md",
    "template/*",
  ]
}

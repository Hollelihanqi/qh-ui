{
  "name": "internal-build-constants",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "internal/build-constants/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/**/*", "!{projectRoot}/dist/**/*"],
      "options": {
        "command": "cd internal/build-constants && pnpm build",
        "cwd": "."
      },
      "cache": true
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd internal/build-constants && pnpm stub",
        "cwd": "."
      }
    }
  }
}

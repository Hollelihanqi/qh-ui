{
  "name": "theme-chalk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/theme-chalk",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist",
        "{workspaceRoot}/dist/hd-custom/theme-chalk"
      ],
      "options": {
        "command": "pnpm run -C packages/theme-chalk build",
        "cwd": "."
      }
    }
  }
}

{
  "$schema": "../../node_modules/release-it/schema/release-it.json",
  "git": {
    "requireCleanWorkingDir": true,
    "commitMessage": "chore(release): release ${name}@${version}",
    "tagName": "${npm.name}@${version}",
    "push": true
  },
  "npm": {
    "publish": true,
    "registry": "https://npm.yto.net.cn/",
    "skipChecks": true,
    "ignoreVersion": false,
    "tag": "latest"
  },
  "hooks": {
    "before:init": ["pnpm build"],
    "after:release": "echo Successfully released ${name} v${version}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md",
      "header": "# Changelog",
      "skipUnstable": true,
      "skipInit": true,
      "silent": true,
      "ignoreRecommendedBump": true
    }
  }
}

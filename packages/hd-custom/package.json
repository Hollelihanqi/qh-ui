{
  "name": "@rdeam/hd-ui",
  "version": "2.1.2",
  "type": "module",
  "module": "es/index.mjs",
  "types": "es/index.d.ts",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs"
    },
    "./global": {
      "types": "./global.d.ts",
      "import": "./global.d.ts",
      "default": "./global.d.ts"
    },
    "./es": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs"
    },
    "./resolvers": {
      "types": "./resolvers/index.d.ts",
      "import": "./resolvers/index.mjs"
    },
    "./share": {
      "types": "./es/share/dist/index.d.ts",
      "import": "./es/share/dist/index.mjs"
    },
    "./es/*.mjs": {
      "types": "./es/*.d.ts",
      "import": "./es/*.mjs"
    },
    "./es/*": {
      "types": [
        "./es/*.d.ts",
        "./es/*/index.d.ts"
      ],
      "import": "./es/*.mjs"
    },
    "./*": "./*"
  },
  "style": "theme-chalk/index.css",
  "sideEffects": [
    "theme-chalk/*.css"
  ],
  "author": {
    "name": "Your Name",
    "email": "your.email@example.com"
  },
  "bugs": {
    "url": "https://github.com/your-name/hd-ui/issues"
  },
  "homepage": "https://github.com/your-name/hd-ui",
  "repository": "https://github.com/your-name/hd-ui",
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "lodash-unified": "^1.0.3",
    "simple-uploader.js": "^0.6.0",
    "spark-md5": "^3.0.2"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "axios": "^1.3.5",
    "echarts": "^5.4.2",
    "element-plus": "^2.6.1",
    "immutable": "^4.3.4",
    "vue": "*",
    "vue-router": "*"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.15.2",
    "element-plus": "^2.13.7",
    "immutable": "^5.1.5"
  }
}

{
  "name": "@yto/custom",
  "version": "2.0.0-beta.15",
  "type": "module",
  "module": "es/index.mjs",
  "types": "es/index.d.ts",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs"
    },
    "./global": {
      "types": "./global.d.ts"
    },
    "./es": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs"
    },
    "./resolvers": {
      "types": "./resolvers/index.d.ts",
      "import": "./resolvers/index.mjs"
    },
    "./es/*.mjs": {
      "types": "./es/*.d.ts",
      "import": "./es/*.mjs"
    },
    "./es/*": {
      "types": [
        "./es/*.d.ts",
        "./es/*/index.d.ts"
      ],
      "import": "./es/*.mjs"
    },
    "./*": "./*"
  },
  "style": "theme-chalk/index.css",
  "sideEffects": [
    "theme-chalk/*.css"
  ],
  "author": {
    "name": "西安技术平台部用户体验设计-李涵祺",
    "email": "02393963@yto.net.cn"
  },
  "bugs": {
    "url": "https://git.yto.net.cn/XiAnCenter/XiAn_yto_t/software-development-kit/yto-engine/-/issues"
  },
  "homepage": "https://git.yto.net.cn/XiAnCenter/XiAn_yto_t/software-development-kit/yto-engine",
  "repository": "https://git.yto.net.cn/XiAnCenter/XiAn_yto_t/software-development-kit/yto-engine",
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "registry": "https://npm.yto.net.cn/"
  },
  "dependencies": {
    "lodash-unified": "^1.0.3",
    "spark-md5": "^3.0.2",
    "simple-uploader.js": "^0.6.0"
  },
  "peerDependencies": {
    "vue": "*",
    "vue-router": "*",
    "@element-plus/icons-vue": "^2.1.0",
    "axios": "^1.3.5",
    "echarts": "^5.4.2",
    "element-plus": "^2.6.1",
    "gold-core": "0.1.17",
    "immutable": "^4.3.4"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "@types/echarts": "^4.9.18",
    "axios": "^1.3.5",
    "element-plus": "^2.6.1",
    "gold-core": "0.1.17",
    "immutable": "^4.3.4"
  }
}
